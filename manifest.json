{
  "manifest_version": 3,
  "name": "AI 智能标签分类",
  "version": "1.2.0",
  "description": "自动分析网页内容，AI 生成多维度智能标签，帮助用户高效管理浏览信息",
  "author": "Vibe Coding",
  "homepage_url": "https://github.com/1010n111/TagSift",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "bookmarks"
  ],
  "host_permissions": [
    "http://*/",
    "https://*/"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI 智能标签分类",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
